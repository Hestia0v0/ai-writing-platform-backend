# Production reverse proxy for docker-compose.prod.yml
#
# Environment (set in .env, passed to the caddy container):
#   DOMAIN      Site address. Use :80 for HTTP-only (e.g. server IP).
#               Set to your public API hostname (e.g. api.example.com) for automatic HTTPS.
#   ACME_EMAIL  Contact for Let's Encrypt expiry notices (recommended when using a domain).

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	log {
		output stdout
		format console
	}

	reverse_proxy api_gateway:8000 {
		health_uri /health/
		health_interval 30s
		health_timeout 5s
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	@https expression {scheme} == "https"
	header @https Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
}
