# Production environment for docker-compose.prod.yml (repository root).
# On the deployment server: cp .env.example .env and fill in values.

POSTGRES_DSN=postgresql://platform:YOUR_URL_ENCODED_PASSWORD@your-host:5432/platform?sslmode=disable
DATABASE_URL=postgresql://platform:YOUR_URL_ENCODED_PASSWORD@your-host:5432/platform?sslmode=disable
JWT_SECRET=change-me-to-a-long-random-secret
CORS_ORIGINS=https://your-frontend.example.com
FRONTEND_URL=https://your-frontend.example.com

DEEPSEEK_API_KEY=
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...

# Caddy reverse proxy (forwards public traffic to api_gateway:8000)
# HTTP-only via server IP: leave DOMAIN as :80
# Automatic HTTPS: set DOMAIN to your public API hostname and set ACME_EMAIL
DOMAIN=:80
ACME_EMAIL=
